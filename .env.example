# .env - Example configuration for the proxy server
HOST=0.0.0.0
PORT=8888
# MLX model to load (must support tool calling for full Claude Code support)
MODEL_NAME=mlx-community/Qwen3-30B-A3B-4bit
# API-exposed model name (what Claude Code sees)
API_MODEL_NAME=claude-4-sonnet-20250514
# Enable verbose debug logging
# VERBOSE=true
