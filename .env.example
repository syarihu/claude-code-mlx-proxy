# .env - Example configuration for the proxy server
HOST=0.0.0.0
PORT=8888
# MLX model to load
MODEL_NAME=mlx-community/GLM-4.5-Air-3bit
# API-exposed model name
API_MODEL_NAME=claude-4-sonnet-20250514
# Inject system-prompt instruction to use <think> tags (default: true)
# Set to false if the model already emits <think> tags natively (e.g. Qwen3)
# INJECT_THINKING_PROMPT=false
# Enable verbose debug logging
# VERBOSE=true
