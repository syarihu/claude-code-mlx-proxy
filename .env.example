# .env - Example configuration for the proxy server
HOST=0.0.0.0
PORT=8888
# URL of the mlx-lm OpenAI-compatible server (must include /v1)
MLX_SERVER_URL=http://localhost:8080/v1
# API-exposed model name (what Claude Code sees)
API_MODEL_NAME=claude-4-sonnet-20250514
# Tool mode: full / slim / none
# TOOL_MODE=slim
# Enable verbose debug logging
# VERBOSE=true
# Web search via Tavily — when set, the proxy intercepts Claude Code's
# WebSearch tool calls and runs them through Tavily, returning real results
# to the local model. Get a free key at https://tavily.com (1,000 searches/mo).
# TAVILY_API_KEY=tvly-...
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_MAX_ITERATIONS=5
